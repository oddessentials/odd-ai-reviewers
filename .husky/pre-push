#!/usr/bin/env sh
# Pre-push hook: Focused quality gates
# Constitution mandate: depcruise in pre-push
# Redundant checks removed: eslint, prettier, tsc (in pre-commit), linkcheck (CI-only)

set -e

echo "Running pre-push quality gates..."

# 1. Circular dependency check (constitution-required)
echo ">> Dependency analysis..."
pnpm exec depcruise router/src --config .dependency-cruiser.cjs

# 2. Build verification
echo ">> Build..."
pnpm run build

# 3. Run tests
echo ">> Tests..."
pnpm --filter ./router test

echo "All pre-push checks passed!"
