# odd-ai-reviewers Environment Variables
# Copy this file to .env and fill in the values for your setup.

# =============================================================================
# AI Provider Keys — at least one required for AI-powered agents
# =============================================================================

# Anthropic (Claude models)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT models)
# OPENAI_API_KEY=sk-proj-...

# Azure OpenAI (all three required)
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# Ollama (local models — no key needed, just the server URL)
# OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# Model Selection
# =============================================================================

# Override default model for cloud AI agents
# MODEL=gpt-4o-mini

# Override model for local_llm agent (default: codellama:7b)
# OLLAMA_MODEL=deepseek-coder:6.7b

# =============================================================================
# Local LLM Tuning (Ollama)
# =============================================================================

# Context window size (default: 4096)
# LOCAL_LLM_NUM_CTX=4096

# Maximum tokens to generate (default: 2048)
# LOCAL_LLM_NUM_PREDICT=2048

# Request timeout in milliseconds (default: 120000)
# LOCAL_LLM_TIMEOUT=120000

# Skip gracefully if Ollama is unavailable (default: false)
# LOCAL_LLM_OPTIONAL=true

# =============================================================================
# Platform Tokens
# =============================================================================

# GitHub API token (for PR comments and check runs)
# GITHUB_TOKEN=ghp_...

# Azure DevOps personal access token
# AZURE_DEVOPS_PAT=...

# Azure DevOps pipeline token (auto-set in ADO pipelines)
# SYSTEM_ACCESSTOKEN=...

# =============================================================================
# Telemetry
# =============================================================================

# Enable/disable telemetry (default: false)
# TELEMETRY_ENABLED=true

# Comma-separated backend list (e.g., console,jsonl)
# TELEMETRY_BACKENDS=jsonl

# File path for JSONL telemetry output
# TELEMETRY_JSONL_PATH=./telemetry.jsonl

# Detail level: minimal, standard, verbose (default: standard)
# TELEMETRY_VERBOSITY=standard

# Max events to buffer before flush (default: 100)
# TELEMETRY_BUFFER_SIZE=100

# Flush interval in milliseconds (default: 5000)
# TELEMETRY_FLUSH_INTERVAL_MS=5000

# =============================================================================
# Utility
# =============================================================================

# Disable colored output (standard convention, any value)
# NO_COLOR=1

# Force pretty output format in non-TTY environments
# FORCE_PRETTY=1

# =============================================================================
# Benchmark (for development/CI)
# =============================================================================

# Required for external benchmark review generation
# ANTHROPIC_API_KEY=sk-ant-...

# Required for external benchmark judging
# MARTIAN_API_KEY=sk-...

# Judge model for external benchmark scoring
# MARTIAN_MODEL=openai/gpt-4.1-mini

# Model ID for benchmark snapshot recording
BENCHMARK_MODEL_ID=gpt-4o

# Provider for benchmark snapshot recording
BENCHMARK_PROVIDER=openai
